<!-- Local rules — SOC Lab V2 -->
<!-- Rule ID ranges:
     100001-100099 : Execution
     100100-100199 : Persistence
     100200-100299 : Credential Access
     100300-100399 : Discovery
     100400-100499 : Defense Evasion
     100500-100599 : Lateral Movement / Brute Force
     100600-100699 : Correlation chains (multi-event)
-->

<!-- ===================== EXECUTION ===================== -->
<group name="sysmon,windows,execution,">

  <rule id="100001" level="10">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)-[eE][nN][cC]|encodedcommand|FromBase64String</field>
    <description>Execution: PowerShell encoded command - $(win.eventdata.commandLine)</description>
    <mitre><id>T1059.001</id></mitre>
  </rule>

  <rule id="100002" level="10">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)(certutil|mshta|regsvr32|rundll32|wscript|cscript)\.exe</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(http|ftp|\\\\)</field>
    <description>Execution: LOLBin loading remote content - $(win.eventdata.image)</description>
    <mitre><id>T1218</id></mitre>
  </rule>

  <rule id="100003" level="8">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)wmic\.exe</field>
    <description>Execution: WMI command execution - $(win.eventdata.commandLine)</description>
    <mitre><id>T1047</id></mitre>
  </rule>

  <rule id="100004" level="10">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)(winword|excel|powerpnt|outlook)\.exe</field>
    <field name="win.eventdata.image" type="pcre2">(?i)(cmd|powershell|wscript|cscript|mshta)\.exe</field>
    <description>Execution: Shell spawned from Office - $(win.eventdata.parentImage)</description>
    <mitre><id>T1204.002</id></mitre>
  </rule>

</group>

<!-- ===================== PERSISTENCE ===================== -->
<group name="sysmon,windows,persistence,">

  <rule id="100100" level="12">
    <if_group>sysmon_event_13</if_group>
    <field name="win.eventdata.targetObject" type="pcre2">\\Services\\(.+)\\ImagePath</field>
    <description>Persistence: Service ImagePath modified - $(win.eventdata.targetObject)</description>
    <mitre><id>T1031</id><id>T1050</id></mitre>
  </rule>

  <rule id="100101" level="12">
    <if_group>sysmon_event_13</if_group>
    <field name="win.eventdata.targetObject" type="pcre2">(?i)\\CurrentVersion\\Run</field>
    <description>Persistence: Registry Run key modified - $(win.eventdata.targetObject)</description>
    <mitre><id>T1547.001</id></mitre>
  </rule>

  <rule id="100102" level="10">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)schtasks\.exe</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)/create</field>
    <description>Persistence: Scheduled task created - $(win.eventdata.commandLine)</description>
    <mitre><id>T1053.005</id></mitre>
  </rule>

</group>

<!-- ===================== CREDENTIAL ACCESS ===================== -->
<group name="sysmon,windows,credential_access,">

  <rule id="100200" level="15">
    <if_group>sysmon_event_10</if_group>
    <field name="win.eventdata.targetImage" type="pcre2">(?i)lsass\.exe</field>
    <description>Credential Access: LSASS accessed by $(win.eventdata.sourceImage)</description>
    <mitre><id>T1003.001</id></mitre>
  </rule>

</group>

<!-- ===================== DISCOVERY ===================== -->
<group name="sysmon,windows,discovery,">

  <rule id="100300" level="6">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)(whoami|net|net1|ipconfig|systeminfo|tasklist|netstat)\.exe</field>
    <description>Discovery: Recon command executed - $(win.eventdata.image)</description>
    <mitre><id>T1082</id><id>T1033</id></mitre>
  </rule>

  <rule id="100301" level="8">
    <if_group>sysmon_event3</if_group>
    <field name="win.eventdata.destinationPort" type="pcre2">^(22|23|80|135|139|443|445|3389|5985)$</field>
    <field name="win.eventdata.initiated" type="pcre2">true</field>
    <description>Discovery: Outbound connection to port $(win.eventdata.destinationPort) by $(win.eventdata.image)</description>
    <mitre><id>T1046</id></mitre>
  </rule>

</group>

<!-- ===================== DEFENSE EVASION ===================== -->
<group name="sysmon,windows,defense_evasion,">

  <rule id="100400" level="12">
    <if_group>sysmon_event8</if_group>
    <description>Defense Evasion: CreateRemoteThread - $(win.eventdata.sourceImage) into $(win.eventdata.targetImage)</description>
    <mitre><id>T1055</id></mitre>
  </rule>

  <rule id="100401" level="10">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(bypass|hidden|noprofile|noninteractive|ExecutionPolicy Bypass)</field>
    <description>Defense Evasion: PowerShell evasion flags - $(win.eventdata.commandLine)</description>
    <mitre><id>T1059.001</id></mitre>
  </rule>

</group>

<!-- ===================== LATERAL MOVEMENT / BRUTE FORCE ===================== -->
<group name="windows,authentication,brute_force,">

  <rule id="100500" level="14" frequency="10" timeframe="60">
    <if_matched_sid>60122</if_matched_sid>
    <same_field>win.eventdata.ipAddress</same_field>
    <description>Brute Force: 10+ failed logons from $(win.eventdata.ipAddress) in 60s</description>
    <mitre><id>T1110.001</id></mitre>
  </rule>

</group>

<!-- ===================== CORRELATION CHAINS ===================== -->
<group name="windows,discovery,correlation,">

  <rule id="100600" level="12" frequency="3" timeframe="60">
    <if_matched_sid>100300</if_matched_sid>
    <same_field>win.eventdata.user</same_field>
    <description>Reconnaissance Chains: 3+ Discovery Commands $(win.eventdata.user) in 60s</description>
    <mitre><id>T1082</id><id>T1033</id></mitre>
  </rule>

</group>

<group name="windows,persistence,correlation,">

  <rule id="100601" level="14" frequency="2" timeframe="120">
    <if_matched_group>persistence</if_matched_group>
    <same_field>win.eventdata.user</same_field>
    <description>Persistence Chains: 2+ Persistence Commands $(win.eventdata.user) in 120s</description>
    <mitre><id>T1053.005</id><id>T1547.001</id></mitre>
  </rule>

</group>